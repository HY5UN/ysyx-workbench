+          when(isValid) {
+            when(flashSkipInit) {
+              state := State.sTX1
+              val rinst = Cat(0x03.U(8.W), in.paddr(23, 0))
+              doWrite(SPIRegs.TX1, rinst)
+            }.otherwise {
+              state := State.sDIV
+              doWrite(SPIRegs.DIVIDER, 1.U)
+            }
+          }
+        }
+        is(State.sDIV) {
+          when(isDone) {
+            state := State.sSS
+            doWrite(SPIRegs.SS, 1.U)
+          }
+        }
+        is(State.sSS) {
+          when(isDone) {
+            state := State.sCTRL
+            doWrite(SPIRegs.CTRL, 0x3440.U)
+          }
+        }
+        is(State.sCTRL) {
+          when(isDone) {
+            val rinst = Cat(0x03.U(8.W), in.paddr(23, 0))
+            state := State.sTX1
+            doWrite(SPIRegs.TX1, rinst)
+          }
+        }
+        is(State.sTX1) {
+          when(isDone) {
+            state := State.sBsy
+            doWrite(SPIRegs.CTRL, 0x3540.U) 
+          }
+        }
+        is(State.sBsy) {
+          when(isDone) {
+            apbState := ApbState.sIdle
+            state := State.sWaitIRQ
+          }
+        }
+        is(State.sWaitIRQ) {
+          when(mspi.io.spi_irq_out) { // 中断拉高 = 传输完成
+            state := State.sTX0
+            doRead(SPIRegs.TX0)
+          }
+        }
+        is(State.sTX0) {
+          when(isDone) {
+            state := State.sOut
+            apbState := ApbState.sIdle
+            val rdata = mspi.io.in.prdata
+            flashReadData := Cat(rdata(7, 0), rdata(15, 8), rdata(23, 16), rdata(31, 24))
+          }
+        }
+
+        is(State.sOut) {
+          in.pready := true.B
+          when(isValid) {
+            flashSkipInit := true.B
+            state         := State.sIdle
+          }
+        }
+      }
+
+      mspi.io.in.paddr   := apbAddr
+      mspi.io.in.pwdata  := apbWdata
+      mspi.io.in.pwrite  := apbWrite
+      mspi.io.in.psel    := apbState === ApbState.sSetup || apbState === ApbState.sAccess
+      mspi.io.in.penable := apbState === ApbState.sAccess
+      mspi.io.in.pprot   := 0.U
+      mspi.io.in.pstrb   := 0xf.U
+
+      when(isValid && in.pwrite) {
+        in.pslverr := true.B
+        state      := State.sOut
+        assert(false.B, "XIP: write to flash address space is not supported!")
+      }
+    }.otherwise {
+      mspi.io.in <> in
+      flashSkipInit := false.B
+    }
   }
 }
