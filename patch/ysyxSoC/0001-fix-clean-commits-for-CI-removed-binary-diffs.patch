+
+    object ApbState extends ChiselEnum {
+      val sIdle, sSetup, sAccess = Value
+    }
+    val apbState = RegInit(ApbState.sAccess)
+
+    val apbAddr                        = RegInit(0.U(32.W))
+    val apbWdata                       = RegInit(0.U(32.W))
+    val apbWrite                       = RegInit(false.B)
+    def doWrite(addr: Int, data: UInt) = {
+      apbAddr  := addr.U
+      apbWdata := data
+      apbWrite := true.B
+      apbState := ApbState.sSetup
+    }
+    def doRead(addr: Int)              = {
+      apbAddr  := addr.U
+      apbWrite := false.B
+      apbState := ApbState.sSetup
+    }
+
+    switch(apbState) {
+      is(ApbState.sIdle) {}
+      is(ApbState.sSetup) {
+        apbState := ApbState.sAccess
+      }
+      is(ApbState.sAccess) {}
+    }
+
+    object SPIRegs {
+      val BASE    = 0x10001000
+      val TX0     = BASE + 0x00
+      val TX1     = BASE + 0x04
+      val CTRL    = BASE + 0x10
+      val DIVIDER = BASE + 0x14
+      val SS      = BASE + 0x18
+    }
+
+    object State extends ChiselEnum {
+      val sIdle, sDIV, sSS, sCTRL, sTX1, sTX0, sBsy, sPoll, sOut, sWaitIRQ = Value
+    }
+
+    val isXIP   = in.paddr >= 0x30000000.U && in.paddr <= 0x3fffffff.U
+    val state   = RegInit(State.sIdle)
+    val isValid = in.psel && in.penable
+    val isDone  = mspi.io.in.pready && mspi.io.in.psel && mspi.io.in.penable
+
+    val flashReadData = RegInit(0.U(32.W))
