diff --git a/bsp/abstract-machine/extra-soc.ld b/bsp/abstract-machine/extra-soc.ld
new file mode 100644
index 000000000..e68670000
--- /dev/null
+++ b/bsp/abstract-machine/extra-soc.ld
@@ -0,0 +1,111 @@
+ENTRY(_start)
+PHDRS { init PT_LOAD;init2 PT_LOAD; text PT_LOAD; data PT_LOAD; }
+
+MEMORY {
+  sram (xrw) : ORIGIN = 0x0f000000, LENGTH = 8k
+  psram (xrw) : ORIGIN = 0x80000000, LENGTH = 4M
+  flash (rx) : ORIGIN = 0x30000000, LENGTH = 16M
+  sdram (xrw) : ORIGIN = 0xa0000000, LENGTH = 128M
+}
+
+
+SECTIONS {
+  . = ORIGIN(flash);
+  .init : {
+    *(entry)
+    *(.init) 
+  } > flash : init
+
+  .init2 : {
+    _init2_start = .;
+    *(.init2)
+  } > sram AT> flash : init2
+  _init2_end = .;
+  _init2_lma = LOADADDR(.init2);
+
+
+  .text : {
+    _text_start = .;
+    *(.text*)
+    
+    *(.rodata*)
+    *(.srodata*)
+    . = ALIGN(4);
+  } > sdram AT> flash : text
+  _text_end = .;
+  _text_lma = LOADADDR(.text);
+
+  /* .rodata : {
+    _rodata_start = .;
+
+  } > sdram AT> flash
+  _rodata_end = .;
+  _rodata_lma = LOADADDR(.rodata); */
+
+  .data.extra : {
+    _data_start = .;
+    /* section information for finsh shell */
+    __fsymtab_start = .;
+    KEEP(*(FSymTab))
+    __fsymtab_end = .;
+    . = ALIGN(8);
+    __vsymtab_start = .;
+    KEEP(*(VSymTab))
+    __vsymtab_end = .;
+    . = ALIGN(8);
+
+    /* section information for initial. */
+    . = ALIGN(8);
+    __rt_init_start = .;
+    KEEP(*(SORT(.rti_fn*)))
+    __rt_init_end = .;
+    . = ALIGN(8);
+
+    __rt_utest_tc_tab_start = .;
+    KEEP(*(UtestTcTab))
+    __rt_utest_tc_tab_end = .;
+
+    . = ALIGN(8);
+    __am_apps_data_start = .;
+    *(__am_apps.data*)
+    *(__am_apps.sdata*)
+    __am_apps_data_end = .;
+    . = ALIGN(8);
+  } > sdram AT> flash : data
+
+  .data : {
+    *(.data*)
+    *(.sdata*)
+    . = ALIGN(4); 
+  } > sdram AT> flash : data
+
+  _data_lma = LOADADDR(.data.extra);
+  _data_end = .;
+  
+  .bss.extra : {
+	  _bss_start = .;
+    . = ALIGN(8);
+    __am_apps_bss_start = .;
+    *(__am_apps.bss*)
+    *(__am_apps.sbss*)
+    *(__am_apps.scommon*)
+    __am_apps_bss_end = .;
+    . = ALIGN(8);
+  } > sdram : data
+
+  .bss : {
+    *(.bss*)
+    *(.sbss*)
+    *(.scommon)
+  } > sdram : data
+  _bss_end = .;
+  _heap_start = .;
+  
+
+  . = ORIGIN(sdram) + LENGTH(sdram);
+  _heap_end = .;
+  _stack_pointer = .;
+  end = .;
+  _end = .;
+}
+
