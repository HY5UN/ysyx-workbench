diff --git a/bsp/abstract-machine/src/context.c b/bsp/abstract-machine/src/context.c
index ee38829ae..e8d766337 100644
--- a/bsp/abstract-machine/src/context.c
+++ b/bsp/abstract-machine/src/context.c
@@ -2,30 +2,117 @@
 #include <klib.h>
 #include <rtthread.h>
 
-static Context* ev_handler(Event e, Context *c) {
-  switch (e.event) {
-    default: printf("Unhandled event ID = %d\n", e.event); assert(0);
+typedef struct
+{
+  rt_ubase_t from;
+  rt_ubase_t to;
+} ContextSwitchArgs;
+
+static Context *ev_handler(Event e, Context *c)
+{
+  switch (e.event)
+  {
+  case EVENT_YIELD:
+  {
+    //printf("EVENT_YIELD\n");
+    rt_thread_t curr_thread = rt_thread_self();
+    //assert(curr_thread != NULL);
+    ContextSwitchArgs *args = (ContextSwitchArgs *)curr_thread->user_data;
+    //assert(args != NULL);
+    if(args->from){
+      *(Context **)args->from = c;
+    }
+    c = *(Context**)args->to;
+    assert(c != NULL);
+
+    break;
+  }
+  case EVENT_ERROR:
+    printf("Event Error happened, cause: %d, ref: %p\n",  e.cause, e.ref);
+    assert(0);
+    break;
+  default:
+    printf("Unhandled event ID = %d\n", e.event);
+    assert(0);
   }
   return c;
 }
 
-void __am_cte_init() {
+void __am_cte_init()
+{
   cte_init(ev_handler);
 }
 
-void rt_hw_context_switch_to(rt_ubase_t to) {
-  assert(0);
+void rt_hw_context_switch_to(rt_ubase_t to)
+{
+  printf("[debug] rt_hw_context_switch_to: to = %08x,*to = %08x\n", (uint32_t)to, *(uint32_t *)to);
+  rt_thread_t curr_thread = rt_thread_self();
+  rt_ubase_t old_user_data = curr_thread->user_data;
+  ContextSwitchArgs args;
+  args.to = to;
+  args.from = 0;
+
+  curr_thread->user_data = (uintptr_t)&args;
+
+  yield();
+
+  curr_thread->user_data = old_user_data;
+
 }
 
-void rt_hw_context_switch(rt_ubase_t from, rt_ubase_t to) {
-  assert(0);
+void rt_hw_context_switch(rt_ubase_t from, rt_ubase_t to)
+{
+  rt_thread_t curr_thread = rt_thread_self();
+  rt_ubase_t old_user_data = curr_thread->user_data;
+  ContextSwitchArgs args;
+  args.from = from;
+  args.to = to; 
+
+  curr_thread->user_data = (uintptr_t)&args;
+  yield();
+  curr_thread->user_data = old_user_data;
 }
 
-void rt_hw_context_switch_interrupt(void *context, rt_ubase_t from, rt_ubase_t to, struct rt_thread *to_thread) {
+void rt_hw_context_switch_interrupt(void *context, rt_ubase_t from, rt_ubase_t to, struct rt_thread *to_thread)
+{
   assert(0);
 }
 
-rt_uint8_t *rt_hw_stack_init(void *tentry, void *parameter, rt_uint8_t *stack_addr, void *texit) {
-  assert(0);
-  return NULL;
+typedef struct
+{
+  uintptr_t tentry;
+  uintptr_t parameter;
+  uintptr_t texit;
+} WrapArg;
+
+void __am_wrap(void *arg)
+{
+  WrapArg *wrap_args = arg;
+  void (*tentry)(void *) = (void (*)(void *))wrap_args->tentry;
+  void *parameter = (void *)wrap_args->parameter;
+  tentry(parameter);
+
+  void (*texit)(void) = (void (*)(void))wrap_args->texit;
+  texit();
+}
+
+rt_uint8_t *rt_hw_stack_init(void *tentry, void *parameter, rt_uint8_t *stack_addr, void *texit)
+{
+  uintptr_t stack_top = (uintptr_t)stack_addr;
+  stack_top &= ~(sizeof(uintptr_t) - 1);
+
+  stack_top -= sizeof(WrapArg);
+
+  WrapArg *wrap_args = (WrapArg *)stack_top;
+  wrap_args->tentry = (uintptr_t)tentry;
+  wrap_args->parameter = (uintptr_t)parameter;
+  wrap_args->texit = (uintptr_t)texit;
+
+  Area kstack;
+  kstack.end = (void *)stack_top;
+  kstack.start = 0;
+
+  Context *cp = kcontext(kstack, __am_wrap, wrap_args);
+
+  return (rt_uint8_t *)cp;
 }
